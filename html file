<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EduPath Global — Study Abroad</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Playfair+Display:ital,wght@1,700&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --red: #D72638;
    --navy: #0D1B40;
    --gold: #F4A823;
    --white: #FFFFFF;
    --light: #F5F7FF;
    --gray: #6B7280;
    --shadow: 0 8px 32px rgba(13,27,64,0.13);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--white);
    color: var(--navy);
    overflow-x: hidden;
  }

  /* ── NAVBAR ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 6vw;
    height: 68px;
    background: var(--navy);
    box-shadow: 0 2px 16px rgba(0,0,0,0.18);
  }
  .logo {
    font-size: 1.35rem; font-weight: 900; color: var(--white);
    letter-spacing: -0.5px;
  }
  .logo span { color: var(--gold); }
  nav ul { list-style: none; display: flex; gap: 2rem; }
  nav ul a { color: rgba(255,255,255,0.82); text-decoration: none; font-weight: 600; font-size: .88rem; letter-spacing: .5px; transition: color .2s; }
  nav ul a:hover { color: var(--gold); }
  .nav-cta {
    background: var(--red); color: var(--white);
    border: none; border-radius: 6px;
    padding: .5rem 1.3rem; font-size: .85rem; font-weight: 700;
    cursor: pointer; letter-spacing: .5px; transition: background .2s;
  }
  .nav-cta:hover { background: #b51f2e; }

  /* ── HERO ── */
  .hero {
    margin-top: 68px;
    min-height: 92vh;
    background: linear-gradient(135deg, var(--navy) 55%, #1a2f6e 100%);
    display: flex; align-items: center;
    padding: 5rem 6vw 3rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -80px; right: -80px;
    width: 520px; height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212,38,56,0.22) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute; bottom: -120px; left: 30%;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244,168,35,0.10) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content { max-width: 600px; z-index: 2; position: relative; }
  .hero-badge {
    display: inline-block;
    background: var(--gold); color: var(--navy);
    font-size: .75rem; font-weight: 800; letter-spacing: 2px;
    padding: .3rem .9rem; border-radius: 20px;
    margin-bottom: 1.4rem; text-transform: uppercase;
  }
  .hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 900; color: var(--white);
    line-height: 1.1; margin-bottom: .6rem;
  }
  .hero h1 .accent { color: var(--red); }
  .hero-italic {
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 1.3rem;
    color: var(--gold); margin-bottom: 1.4rem;
    display: block;
  }
  .hero p {
    color: rgba(255,255,255,0.72); font-size: 1rem; line-height: 1.7;
    max-width: 480px; margin-bottom: 2.2rem;
  }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    background: var(--red); color: var(--white);
    border: none; border-radius: 8px;
    padding: .85rem 2rem; font-size: .95rem; font-weight: 700;
    cursor: pointer; letter-spacing: .5px;
    box-shadow: 0 4px 18px rgba(215,38,56,0.35);
    transition: transform .18s, box-shadow .18s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(215,38,56,0.45); }
  .btn-outline {
    background: transparent; color: var(--white);
    border: 2px solid rgba(255,255,255,0.45); border-radius: 8px;
    padding: .85rem 2rem; font-size: .95rem; font-weight: 700;
    cursor: pointer; transition: border-color .2s, color .2s;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 3rem;
    flex-wrap: wrap;
  }
  .stat { color: var(--white); }
  .stat strong { display: block; font-size: 2rem; font-weight: 900; color: var(--gold); line-height: 1; }
  .stat span { font-size: .78rem; color: rgba(255,255,255,0.6); letter-spacing: .5px; text-transform: uppercase; }

  /* ── RIBBON ── */
  .ribbon {
    background: var(--red);
    padding: .9rem 6vw;
    display: flex; gap: 2rem; flex-wrap: wrap; align-items: center; justify-content: center;
  }
  .ribbon-item {
    color: var(--white); font-weight: 700; font-size: .88rem; letter-spacing: .5px;
    display: flex; align-items: center; gap: .4rem;
  }
  .ribbon-item::before { content: '✦'; color: var(--gold); }

  /* ── SECTION SHARED ── */
  section { padding: 5rem 6vw; }
  .section-label {
    text-transform: uppercase; letter-spacing: 2.5px; font-size: .72rem;
    font-weight: 800; color: var(--red); margin-bottom: .5rem;
  }
  .section-title {
    font-size: clamp(1.7rem, 3.5vw, 2.6rem); font-weight: 900;
    color: var(--navy); line-height: 1.15; margin-bottom: 1rem;
  }
  .section-title span { color: var(--red); }
  .section-sub { color: var(--gray); font-size: .95rem; line-height: 1.7; max-width: 560px; }

  /* ── DESTINATIONS ── */
  .destinations { background: var(--light); }
  .dest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .dest-card {
    background: var(--white);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform .22s, box-shadow .22s;
    cursor: pointer;
  }
  .dest-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(13,27,64,0.18); }
  .dest-img {
    height: 140px;
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem;
    position: relative;
  }
  .india-bg { background: linear-gradient(135deg,#FF9933 33%,#fff 33% 66%,#138808 66%); }
  .uk-bg { background: linear-gradient(135deg,#012169 40%,#C8102E 60%); }
  .canada-bg { background: linear-gradient(135deg,#FF0000 30%,#fff 30% 70%,#FF0000 70%); }
  .aus-bg { background: linear-gradient(135deg,#00008B 40%,#FFD700 60%); }
  .dest-body { padding: 1.1rem 1.2rem 1.4rem; }
  .dest-body h3 { font-size: 1rem; font-weight: 800; margin-bottom: .3rem; }
  .dest-body p { font-size: .8rem; color: var(--gray); margin-bottom: .8rem; }
  .dest-tag {
    display: inline-block;
    background: rgba(215,38,56,0.09); color: var(--red);
    font-size: .72rem; font-weight: 700; padding: .2rem .7rem;
    border-radius: 20px;
  }

  /* ── SUCCESS STORIES ── */
  .stories-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 1.5rem;
  }
  .story-card {
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow);
    overflow: hidden;
    position: relative;
  }
  .story-top {
    background: linear-gradient(135deg, var(--navy), #1a2f6e);
    padding: 1.4rem 1.4rem 1rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .avatar {
    width: 54px; height: 54px; border-radius: 50%;
    background: var(--gold); display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; font-weight: 900; color: var(--navy);
    flex-shrink: 0; border: 3px solid rgba(255,255,255,0.3);
  }
  .story-name { color: var(--white); font-weight: 800; font-size: 1.05rem; }
  .story-prog { color: rgba(255,255,255,0.65); font-size: .78rem; margin-top: .2rem; }
  .story-stamp {
    position: absolute; top: 1rem; right: 1rem;
    background: rgba(215,38,56,0.9); color: var(--white);
    font-size: .62rem; font-weight: 900; letter-spacing: 1px;
    padding: .3rem .6rem; border-radius: 6px;
    text-transform: uppercase; border: 2px solid rgba(255,255,255,0.4);
  }
  .story-body { padding: 1.2rem 1.4rem 1.4rem; }
  .scholarship-badge {
    display: inline-flex; align-items: center; gap: .4rem;
    background: linear-gradient(90deg, var(--gold), #f9c851);
    color: var(--navy); font-weight: 900; font-size: .9rem;
    padding: .4rem .9rem; border-radius: 8px;
    margin-bottom: .9rem;
  }
  .scholarship-badge .pct { font-size: 1.3rem; }
  .story-uni { font-weight: 700; font-size: .9rem; color: var(--navy); margin-bottom: .25rem; }
  .story-country { font-size: .78rem; color: var(--gray); }

  /* ── UNIVERSITIES ── */
  .universities { background: var(--navy); }
  .universities .section-label { color: var(--gold); }
  .universities .section-title { color: var(--white); }
  .universities .section-title span { color: var(--gold); }
  .universities .section-sub { color: rgba(255,255,255,0.6); }
  .uni-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1.2rem;
    margin-top: 2.5rem;
  }
  .uni-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 1.3rem 1rem;
    text-align: center;
    transition: background .2s, border-color .2s;
    cursor: pointer;
  }
  .uni-card:hover { background: rgba(244,168,35,0.12); border-color: var(--gold); }
  .uni-icon { font-size: 2rem; margin-bottom: .6rem; }
  .uni-name { color: var(--white); font-weight: 700; font-size: .82rem; line-height: 1.3; }
  .uni-location { color: rgba(255,255,255,0.45); font-size: .72rem; margin-top: .25rem; }

  /* ── PROCESS ── */
  .process { background: var(--light); }
  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 1.5rem; margin-top: 2.5rem;
  }
  .step {
    background: var(--white); border-radius: 14px;
    padding: 1.8rem 1.5rem; box-shadow: var(--shadow);
    position: relative; overflow: hidden;
  }
  .step::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 4px; background: var(--red);
  }
  .step-num {
    font-size: 3rem; font-weight: 900; color: rgba(215,38,56,0.1);
    line-height: 1; margin-bottom: .6rem;
  }
  .step-icon { font-size: 1.8rem; margin-bottom: .7rem; }
  .step h3 { font-size: .95rem; font-weight: 800; margin-bottom: .4rem; }
  .step p { font-size: .8rem; color: var(--gray); line-height: 1.6; }

  /* ── CTA BANNER ── */
  .cta-banner {
    background: linear-gradient(120deg, var(--red) 0%, #8B1425 100%);
    padding: 4.5rem 6vw;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 2rem;
  }
  .cta-banner h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 900;
    color: var(--white); max-width: 520px; line-height: 1.2;
  }
  .cta-banner h2 span { color: var(--gold); }
  .btn-white {
    background: var(--white); color: var(--red);
    border: none; border-radius: 8px;
    padding: 1rem 2.4rem; font-size: 1rem; font-weight: 800;
    cursor: pointer; white-space: nowrap;
    transition: transform .18s;
  }
  .btn-white:hover { transform: translateY(-2px); }

  /* ── FOOTER ── */
  footer {
    background: #07101F;
    padding: 3rem 6vw 1.5rem;
  }
  .footer-top {
    display: flex; flex-wrap: wrap; gap: 3rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-brand { flex: 1; min-width: 200px; }
  .footer-logo { font-size: 1.4rem; font-weight: 900; color: var(--white); margin-bottom: .7rem; }
  .footer-logo span { color: var(--gold); }
  .footer-brand p { color: rgba(255,255,255,0.45); font-size: .82rem; line-height: 1.7; max-width: 260px; }
  .footer-col { min-width: 140px; }
  .footer-col h4 { color: var(--gold); font-size: .78rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem; font-weight: 800; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .5rem; }
  .footer-col ul a { color: rgba(255,255,255,0.5); font-size: .82rem; text-decoration: none; transition: color .2s; }
  .footer-col ul a:hover { color: var(--white); }
  .footer-contact { min-width: 200px; }
  .footer-contact h4 { color: var(--gold); font-size: .78rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem; font-weight: 800; }
  .contact-line { display: flex; gap: .6rem; color: rgba(255,255,255,0.55); font-size: .82rem; margin-bottom: .6rem; align-items: flex-start; }
  .contact-icon { color: var(--gold); flex-shrink: 0; margin-top: .05rem; }
  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    align-items: center;
  }
  .footer-bottom p { color: rgba(255,255,255,0.3); font-size: .76rem; }
  .tagline-footer {
    background: var(--red); color: var(--white);
    font-size: .72rem; font-weight: 800; letter-spacing: 1px;
    padding: .25rem .8rem; border-radius: 20px;
    text-transform: uppercase;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    nav ul { display: none; }
    .hero { padding-top: 3rem; min-height: auto; }
    .hero-stats { gap: 1.5rem; }
    .dest-img { height: 110px; }
    .cta-banner { text-align: center; justify-content: center; }
  }
</style>
</head>
